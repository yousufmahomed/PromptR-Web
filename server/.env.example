# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://promptr_user:your_password@localhost:5432/promptr_db

# Firebase Admin SDK
# Download your service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Google Play Billing
GOOGLE_PLAY_PACKAGE_NAME=com.yourname.promptr

# Yoco Payment Gateway
YOCO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
YOCO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
YOCO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
