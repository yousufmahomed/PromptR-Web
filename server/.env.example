# Database
DATABASE_URL="postgresql://user:password@localhost:5432/promptr_db"

# JWT Secret (change in production!)
JWT_SECRET="your-jwt-secret-here"

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Yoco Payment Gateway
YOCO_SECRET_KEY="sk_test_your_yoco_secret_key"
YOCO_PUBLIC_KEY="pk_test_your_yoco_public_key"
YOCO_WEBHOOK_SECRET="your_yoco_webhook_secret"

# Frontend URL (for CORS and payment redirects)
FRONTEND_URL="http://localhost:5173"

# Server Port
PORT=3001
